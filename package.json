{
  "name": "monthcolor-reservation",
  "version": "1.0.0",
  "description": "MONTH COLOR 予約・会計・顧客管理システム",
  "main": "index.js",
  "scripts": {
    "worker": "node worker.js",
    "worker:watch": "node worker.js --watch",
    "worker:retry": "node worker.js --retry",
    "sync": "node sync_from_email.js",
    "sync:dry": "node sync_from_email.js --dry-run",
    "sync:slots": "node sync_slots.js",
    "sync:slots:3months": "node sync_slots.js --months 3",
    "sync:cs": "node sync_comingsoon.js",
    "sync:cs:week": "node sync_comingsoon.js --days 7",
    "sync:cs:preview": "node sync_comingsoon.js --preview",
    "setup:tasks": "powershell -ExecutionPolicy Bypass -File setup/setup_tasks.ps1",
    "login:peatix": "node scripts/login-peatix.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@vercel/blob": "^2.3.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "playwright": "^1.43.0",
    "playwright-extra": "^4.3.6",
    "playwright-extra-plugin-stealth": "^0.0.1",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "resend": "^6.12.0",
    "uuid": "^9.0.1"
  }
}
