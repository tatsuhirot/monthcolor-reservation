{
  "routes": [
    { "src": "/api/([^/?]+)(.*)", "dest": "/api/router?name=$1" },
    { "src": "/admin",      "dest": "/admin.html" },
    { "src": "/register",   "dest": "/register.html" },
    { "src": "/report",     "dest": "/report.html" },
    { "src": "/customers",  "dest": "/customers.html" },
    { "src": "/reserve",    "dest": "/reservation.html" },
    { "src": "/close",      "dest": "/close.html" },
    { "src": "/menu",       "dest": "/menu.html" },
    { "src": "/",           "dest": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron?type=remind",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron?type=morning-report",
      "schedule": "0 23 * * *"
    }
  ]
}
