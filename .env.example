# ─────────────────────────────────────────────────────────────
#  MONTH COLOR 予約システム — 環境変数サンプル
#  Vercel Dashboard > Settings > Environment Variables に登録する
#  VPS (worker.js 用) は ~/hpb-calendar/.env にコピーして使う
# ─────────────────────────────────────────────────────────────

# ── 必須 ─────────────────────────────────────────────────────

# Vercel Blob の読み書きトークン（Vercel Storage > Blob から取得）
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# スタッフ画面・会計画面・レポートの共通パスワード
ADMIN_PASSWORD=your-secure-password

# SalonBoard ログイン情報（worker.js / sync_slots.js で使用）
SALONBOARD_LOGIN_ID=your-salonboard-id
SALONBOARD_PASSWORD=your-salonboard-password

# メール送信 (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxx
MAIL_FROM=MONTH COLOR <noreply@monthcolor.jp>

# ── 推奨 ─────────────────────────────────────────────────────

# 予約サイトのURL（サンクスメールの「次回予約はこちら」リンク）
SITE_URL=https://monthcolor-reservation.vercel.app

# 店舗情報（領収書・メールに使用）
SHOP_NAME=MONTH COLOR 東陽町
SHOP_ADDRESS=東京都江東区東陽4-1-2 大朋ビル4F
SHOP_PHONE=03-xxxx-xxxx
SHOP_EMAIL=info@monthcolor.jp

# スタッフ通知メール（新規予約・変更・キャンセル時）
STAFF_NOTIFY_EMAIL=staff@monthcolor.jp

# ── LINE 通知（任意）────────────────────────────────────────

# LINE Messaging API チャネルアクセストークン（会計完了・リピーター来店通知）
LINE_CHANNEL_ACCESS_TOKEN=

# 通知送信先のLINEユーザーID（LINE Developers > Messaging API > Users で確認）
LINE_OWNER_USER_ID=

# LINE Notify トークン（旧フロー。Messaging API を使う場合は不要）
LINE_NOTIFY_TOKEN=

# ── Vercel Cron 保護（任意）─────────────────────────────────

# Vercel が Cron 実行時に付与するシークレット（Vercel Dashboard で設定）
CRON_SECRET=

# ── 開発用 ──────────────────────────────────────────────────

# Playwright をヘッドモードで実行（デバッグ時: false）
PLAYWRIGHT_HEADLESS=true

# ローカル Express サーバーのポート（Vercel では不使用）
PORT=3000

# CORS 許可オリジン（カンマ区切り。空欄 = 全許可）
ALLOWED_ORIGINS=
